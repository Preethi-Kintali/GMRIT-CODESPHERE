# ----------------------------------------
# Server Configuration
# ----------------------------------------
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ----------------------------------------
# Database
# ----------------------------------------
DB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/dbname

# ----------------------------------------
# External APIs (Required)
# ----------------------------------------
# Stream.io for Video Calls and Chat
STREAM_API_KEY=your_stream_api_key_here
STREAM_API_SECRET=your_stream_api_secret_here

# Clerk
CLERK_SECRET_KEY=your_clerk_secret_key_here
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret_here

# ----------------------------------------
# Email Provider (Choose 'gmail' or 'resend')
# ----------------------------------------
EMAIL_SERVICE=gmail
EMAIL_FROM=GMRIT CodeSphere <your-email@gmail.com>

# If using Gmail:
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# If using Resend:
RESEND_API_KEY=re_your_resend_api_key_here

# ----------------------------------------
# Background Jobs (Inngest) - Optional natively
# ----------------------------------------
INNGEST_EVENT_KEY=your_inngest_event_key_here
INNGEST_SIGNING_KEY=your_inngest_signing_key_here
